  --sombra-sm: 0 2px 8px rgba(107, 78, 61, 0.10);
  --sombra-md: 0 4px 16px rgba(107, 78, 61, 0.12);
  --sombra-lg: 0 8px 24px rgba(107, 78, 61, 0.14);
  --sombra-xl: 0 16px 32px rgba(107, 78, 61, 0.16);
  
