<file path="src/pages/Cardapio.css">
.cardapio {
  padding: var(--espacamento-2xl) var(--espacamento-3xl);
  max-width: 1600px;
  margin: 0 auto;
}

/* ========== HEADER ========== */
.page-header {
  margin-bottom: var(--espacamento-2xl);
}

.page-header h1 {
  font-family: var(--fonte-display);
  font-size: 2.75rem;
  font-weight: var(--peso-extrabold);
  color: var(--azul-noite);
  margin-bottom: var(--espacamento-sm);
  letter-spacing: -0.02em;
}

.page-header p {
  font-size: 1.125rem;
  color: var(--marrom-cafe);
  font-weight: var(--peso-medium);
}

/* ========== FILTROS LUXUOSOS ========== */
.filters {
  display: flex;
  gap: var(--espacamento-md);
  margin-bottom: var(--espacamento-2xl);
  flex-wrap: wrap;
}

.filters button {
  display: flex;
  align-items: center;
  gap: var(--espacamento-sm);
  padding: 1rem 1.75rem;
  background: var(--branco-puro);
  border: 2px solid var(--cinza-platina);
  border-radius: var(--raio-lg);
  font-family: var(--fonte-principal);
  font-size: 1rem;
  font-weight: var(--peso-semibold);
  color: var(--azul-noite);
  cursor: pointer;
  transition: all var(--transicao-normal);
  box-shadow: var(--sombra-xs);
  position: relative;
  overflow: hidden;
}

.filters button::before {
  content: '';
  position: absolute;
  inset: 0;
  background: var(--gradiente-luxo);
  opacity: 0;
  transition: opacity var(--transicao-normal);
  z-index: 0;
}

.filters button > * {
  position: relative;
  z-index: 1;
}

.filters button:hover {
  border-color: var(--dourado-champagne);
  box-shadow: var(--sombra-sm);
  transform: translateY(-2px);
}

.filters button.active {
  border-color: transparent;
  box-shadow: var(--sombra-dourada);
}

.filters button.active::before {
  opacity: 1;
}

.filters button.active .filtro-texto,
.filters button.active .filtro-count {
  color: var(--branco-puro);
}

.filtro-icon {
  font-size: 1.25rem;
}

.filtro-texto {
  display: flex;
  align-items: center;
  gap: var(--espacamento-xs);
}

.filtro-count {
  font-size: 0.875rem;
  opacity: 0.8;
}

/* ========== GRID DE ITENS ========== */
.itens-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
  gap: var(--espacamento-xl);
  margin-bottom: var(--espacamento-3xl);
}

/* ========== CARDS LUXUOSOS ========== */
.item-card {
  background: var(--branco-puro);
  border-radius: var(--raio-xl);
  overflow: hidden;
  box-shadow: var(--sombra-sm);
  border: 1px solid var(--cinza-platina);
  transition: all var(--transicao-normal);
  display: flex;
  flex-direction: column;
  position: relative;
}

.item-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3px;
  background: var(--gradiente-luxo);
  opacity: 0;
  transition: opacity var(--transicao-normal);
}

.item-card:hover {
  box-shadow: var(--sombra-lg);
  border-color: var(--dourado-claro);
  transform: translateY(-4px);
}

.item-card:hover::before {
  opacity: 1;
}

.item-content {
  padding: var(--espacamento-xl);
  display: flex;
