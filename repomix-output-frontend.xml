  padding: var(--espacamento-xl);
}

.modal-content {
  background: var(--branco-puro);
  border-radius: var(--raio-xl);
  padding: var(--espacamento-2xl);
  max-width: 450px;
  width: 100%;
  box-shadow: var(--sombra-xl);
  position: relative;
}

.modal-close {
  position: absolute;
  top: var(--espacamento-md);
  right: var(--espacamento-md);
  background: none;
  border: none;
  font-size: 2rem;
  color: var(--cinza-grafite);
  cursor: pointer;
  width: 40px;
  height: 40px;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: var(--raio-md);
  transition: all var(--transicao-rapida);
}

.modal-close:hover {
  background: var(--creme-escuro);
  color: var(--azul-noite);
}

.modal-tabs {
  display: flex;
  gap: var(--espacamento-sm);
  margin-bottom: var(--espacamento-xl);
  border-bottom: 2px solid var(--cinza-platina);
}

.modal-tabs button {
  flex: 1;
  padding: var(--espacamento-md);
  background: none;
  border: none;
  font-weight: var(--peso-semibold);
  color: var(--cinza-grafite);
  cursor: pointer;
  position: relative;
  transition: all var(--transicao-normal);
}

.modal-tabs button.active {
  color: var(--azul-noite);
}

.modal-tabs button.active::after {
  content: '';
  position: absolute;
  bottom: -2px;
  left: 0;
  right: 0;
  height: 2px;
  background: var(--gradiente-luxo);
}

.auth-form {
  display: flex;
  flex-direction: column;
  gap: var(--espacamento-md);
}

.auth-form h3 {
  font-family: var(--fonte-display);
  font-size: 1.75rem;
  color: var(--azul-noite);
  margin-bottom: var(--espacamento-md);
}

.auth-form input {
  padding: var(--espacamento-md);
  border: 2px solid var(--cinza-platina);
  border-radius: var(--raio-md);
  font-size: 1rem;
  transition: all var(--transicao-normal);
  font-family: var(--fonte-principal);
}

.auth-form input:focus {
  outline: none;
  border-color: var(--dourado-champagne);
  box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
}

.auth-form .btn-primary {
  margin-top: var(--espacamento-md);
}

.link-esqueci {
  text-align: center;
  color: var(--dourado-champagne);
  font-size: 0.9375rem;
  text-decoration: none;
  font-weight: var(--peso-semibold);
}

.link-esqueci:hover {
  text-decoration: underline;
}

/* ========== RESPONSIVO ========== */
@media (max-width: 1024px) {
  .hero-content h1 {
    font-size: 3rem;
  }

  .sobre-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 768px) {
  .header-content {
    flex-wrap: wrap;
  }

  .main-nav {
    order: 3;
    width: 100%;
    justify-content: center;
  }

  .hero-content h1 {
    font-size: 2.5rem;
  }

  .hero-subtitle {
    font-size: 1.125rem;
  }

  .hero-buttons {
    flex-direction: column;
  }

  .circulo-dourado {
    width: 250px;
    height: 250px;
  }

  .itens-destaque,
  .atendimento-grid {
    grid-template-columns: 1fr;
  }
}
</file>

