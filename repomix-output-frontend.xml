.sidebar {
  width: 280px;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20px);
  border-right: 1px solid rgba(251, 146, 60, 0.2);
  display: flex;
  flex-direction: column;
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  z-index: var(--z-sidebar);
  box-shadow: 4px 0 24px rgba(251, 146, 60, 0.12);
}

/* ========== HEADER COM LOGO ========== */
.sidebar-header {
  padding: var(--espacamento-xl);
  border-bottom: 1px solid rgba(251, 146, 60, 0.15);
  background: linear-gradient(135deg, rgba(254, 243, 199, 0.6), rgba(254, 215, 170, 0.4));
}

.logo {
  display: flex;
  align-items: center;
  gap: var(--espacamento-md);
  cursor: pointer;
}

.logo-imagem {
  width: 56px;
  height: 56px;
  flex-shrink: 0;
  position: relative;
}

.logo-imagem img {
  width: 100%;
  height: 100%;
  object-fit: contain;
  filter: drop-shadow(0 4px 12px rgba(251, 146, 60, 0.3));
}

.logo-fallback {
  width: 100%;
  height: 100%;
}

.logo-fallback svg {
  width: 100%;
  height: 100%;
  filter: drop-shadow(0 4px 12px rgba(251, 146, 60, 0.3));
}

.logo-text h2 {
  font-family: var(--fonte-display);
  font-size: 1.25rem;
  font-weight: var(--peso-extrabold);
  background: var(--gradiente-principal);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  margin: 0;
  line-height: 1.2;
}

.logo-text p {
  font-size: 0.75rem;
  color: var(--cinza-escuro);
  font-weight: var(--peso-semibold);
  margin: 0;
  margin-top: 2px;
}

/* ========== NAVEGAÇÃO ========== */
.sidebar-nav {
  flex: 1;
  padding: var(--espacamento-lg) 0;
  overflow-y: auto;
}

.nav-item {
  display: flex;
  align-items: center;
  gap: var(--espacamento-md);
  padding: var(--espacamento-md) var(--espacamento-lg);
  color: var(--cinza-escuro);
  text-decoration: none;
  transition: all var(--transicao-normal);
  font-weight: var(--peso-medium);
  position: relative;
  margin: 4px var(--espacamento-md);
  border-radius: var(--raio-md);
}

.nav-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 4px;
  height: 0;
  background: var(--gradiente-principal);
  border-radius: 0 var(--raio-sm) var(--raio-sm) 0;
  transition: height var(--transicao-normal);
}

.nav-item:hover {
  background: linear-gradient(135deg, rgba(251, 146, 60, 0.12), rgba(254, 243, 199, 0.15));
  color: var(--laranja-intenso);
  transform: translateX(4px);
}

.nav-item:hover::before {
  height: 60%;
}

.nav-item.active {
  background: linear-gradient(135deg, rgba(251, 146, 60, 0.18), rgba(254, 243, 199, 0.25));
  color: var(--azul-tocantins);
  font-weight: var(--peso-bold);
  box-shadow: var(--sombra-sm);
}

.nav-item.active::before {
  height: 80%;
}

.nav-icon {
  font-size: 1.5rem;
  min-width: 28px;
  text-align: center;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-label {
  flex: 1;
  font-size: 0.9375rem;
}

.active-indicator {
  width: 8px;
  height: 8px;
  background: var(--gradiente-principal);
  border-radius: 50%;
  box-shadow: 0 0 12px rgba(251, 146, 60, 0.8);
  animation: pulse-indicator 2s ease-in-out infinite;
}

@keyframes pulse-indicator {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.6;
    transform: scale(1.2);
  }
}

/* ========== FOOTER ========== */
.sidebar-footer {
  padding: var(--espacamento-lg);
  border-top: 1px solid rgba(251, 146, 60, 0.15);
  background: linear-gradient(135deg, rgba(254, 243, 199, 0.6), rgba(254, 215, 170, 0.4));
}

.user-profile {
  display: flex;
  align-items: center;
  gap: var(--espacamento-md);
  padding: var(--espacamento-md);
  background: rgba(255, 255, 255, 0.8);
  border-radius: var(--raio-md);
  box-shadow: var(--sombra-xs);
  cursor: pointer;
  transition: all var(--transicao-normal);
  border: 1px solid rgba(251, 146, 60, 0.1);
}

.user-profile:hover {
