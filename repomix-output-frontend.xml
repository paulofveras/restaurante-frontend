<file path="src/App.css">
/* ==========================================
   🌅 SOL DO CERRADO - ESTILOS GLOBAIS (VERSÃO CLARA)
   ========================================== */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
}

body {
  font-family: var(--fonte-principal);
  color: var(--preto);
  background: var(--fundo-gradiente);
  background-attachment: fixed;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
  min-height: 100vh;
}

/* Seleção de texto */
::selection {
  background: var(--amarelo-sol);
  color: var(--azul-tocantins);
}

/* Scrollbar personalizada */
::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

::-webkit-scrollbar-track {
  background: rgba(255, 255, 255, 0.3);
  border-radius: var(--raio-full);
}

::-webkit-scrollbar-thumb {
  background: linear-gradient(180deg, var(--laranja-vibrante), var(--vermelho-suave));
  border-radius: var(--raio-full);
  transition: background var(--transicao-normal);
}

::-webkit-scrollbar-thumb:hover {
  background: linear-gradient(180deg, var(--laranja-intenso), var(--vermelho-suave));
}

/* Layout Principal */
.app {
  display: flex;
  min-height: 100vh;
  position: relative;
}

.main-content {
  flex: 1;
  margin-left: 280px;
  min-height: 100vh;
  transition: margin-left var(--transicao-normal);
  position: relative;
  padding: 0;
}

/* Page Header */
.page-header {
  margin-bottom: var(--espacamento-xl);
  position: relative;
  padding-bottom: var(--espacamento-lg);
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 100px;
  height: 4px;
  background: var(--gradiente-principal);
  border-radius: var(--raio-full);
  box-shadow: 0 2px 8px rgba(251, 146, 60, 0.4);
}

.page-header h1 {
  font-family: var(--fonte-display);
  font-size: 2.5rem;
  font-weight: var(--peso-extrabold);
  color: var(--azul-tocantins);
  margin-bottom: var(--espacamento-sm);
  background: var(--gradiente-principal);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-shadow: 0 2px 4px rgba(251, 146, 60, 0.1);
}

.page-header p {
  color: var(--cinza-escuro);
  font-size: 1.0625rem;
  font-weight: var(--peso-medium);
}

/* Cards */
.card {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-radius: var(--raio-xl);
  box-shadow: var(--sombra-md);
  overflow: hidden;
  transition: all var(--transicao-normal);
  border: 1px solid rgba(251, 146, 60, 0.15);
}

.card:hover {
  box-shadow: var(--sombra-lg);
  transform: translateY(-4px);
  border-color: rgba(251, 146, 60, 0.3);
}

.card-header {
  padding: var(--espacamento-xl);
  border-bottom: 1px solid rgba(251, 146, 60, 0.1);
  background: linear-gradient(135deg, rgba(254, 243, 199, 0.6), rgba(254, 215, 170, 0.4));
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 1.375rem;
  font-weight: var(--peso-bold);
  color: var(--azul-tocantins);
  margin: 0;
  font-family: var(--fonte-display);
}

.card-body {
  padding: var(--espacamento-xl);
  background: rgba(255, 255, 255, 0.6);
}

/* Tabelas */
.table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
}

.table thead th {
  text-align: left;
  padding: var(--espacamento-md) var(--espacamento-lg);
  font-weight: var(--peso-bold);
  color: var(--azul-tocantins);
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  border-bottom: 2px solid rgba(251, 146, 60, 0.2);
  background: linear-gradient(135deg, rgba(254, 243, 199, 0.5), rgba(254, 215, 170, 0.3));
}

.table tbody td {
  padding: var(--espacamento-lg);
  border-bottom: 1px solid rgba(251, 146, 60, 0.08);
  color: var(--preto);
  font-size: 0.9375rem;
}

.table tbody tr {
  transition: all var(--transicao-rapida);
  background: transparent;
}

.table tbody tr:hover {
  background: rgba(251, 146, 60, 0.08);
}

.table tbody tr:last-child td {
  border-bottom: none;
}

/* Botões */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--espacamento-sm);
  padding: 0.875rem 1.75rem;
  border: none;
  border-radius: var(--raio-lg);
  font-weight: var(--peso-semibold);
  font-size: 1rem;
  cursor: pointer;
  transition: all var(--transicao-normal);
  position: relative;
  overflow: hidden;
}

.btn-primary {
  background: var(--gradiente-principal);
  color: var(--branco);
  box-shadow: var(--sombra-sol);
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: var(--sombra-xl);
}

.btn-text {
  background: none;
  color: var(--laranja-intenso);
  padding: var(--espacamento-sm) var(--espacamento-md);
  font-weight: var(--peso-bold);
  border-radius: var(--raio-md);
}

.btn-text:hover {
  background: rgba(251, 146, 60, 0.15);
}

/* Loading */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: var(--espacamento-lg);
}

.loading-spinner {
  width: 80px;
  height: 80px;
}

.loading-container p {
  color: var(--azul-tocantins);
  font-size: 1.125rem;
  font-weight: var(--peso-semibold);
}

/* Responsivo */
@media (max-width: 768px) {
  .main-content {
    margin-left: 0;
  }
  
  .page-header h1 {
    font-size: 2rem;
  }
}

/* Animações */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.animate-fade-in-up {
  animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}
</file>

