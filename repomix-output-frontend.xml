  /* ========== BORDAS REFINADAS ========== */
  --raio-sm: 6px;
  --raio-md: 10px;
  --raio-lg: 14px;
  --raio-xl: 18px;
  --raio-full: 9999px;
  
  /* ========== SOMBRAS SUTIS E ELEGANTES ========== */
  
