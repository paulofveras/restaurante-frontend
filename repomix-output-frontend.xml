  height: 40px;
  border-radius: 50%;
  background: var(--gradiente-principal);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.25rem;
  flex-shrink: 0;
  box-shadow: var(--sombra-sm);
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name {
  font-size: 0.9375rem;
  font-weight: var(--peso-bold);
  color: var(--azul-tocantins);
  margin: 0;
}

.user-role {
  font-size: 0.75rem;
  color: var(--cinza-medio);
  margin: 0;
