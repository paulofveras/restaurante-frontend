<file path="src/App.css">
/* ==========================================
   🌟 SOL DO CERRADO - APP STYLES (LUXO)
   ========================================== */

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  font-size: 16px;
  scroll-behavior: smooth;
}

body {
  font-family: var(--fonte-principal);
  color: var(--azul-noite);
  background: var(--gradiente-fundo);
  background-attachment: fixed;
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  overflow-x: hidden;
  min-height: 100vh;
}

/* ========== SELEÇÃO DE TEXTO ========== */
::selection {
  background: var(--dourado-champagne);
  color: var(--azul-noite);
}

/* ========== SCROLLBAR PERSONALIZADA ========== */
::-webkit-scrollbar {
  width: 12px;
  height: 12px;
}

::-webkit-scrollbar-track {
  background: var(--creme-escuro);
  border-radius: var(--raio-full);
}

::-webkit-scrollbar-thumb {
  background: var(--gradiente-luxo);
  border-radius: var(--raio-full);
  border: 2px solid var(--creme-escuro);
  transition: all var(--transicao-normal);
}

::-webkit-scrollbar-thumb:hover {
  border-width: 1px;
}

/* ========== LAYOUT PRINCIPAL ========== */
.app {
  display: flex;
  min-height: 100vh;
  position: relative;
}

.main-content {
  flex: 1;
  margin-left: 280px;
  min-height: 100vh;
  transition: margin-left var(--transicao-normal);
  position: relative;
  padding: 0;
}

/* ========== PAGE HEADER ========== */
.page-header {
  margin-bottom: var(--espacamento-2xl);
  position: relative;
  padding-bottom: var(--espacamento-lg);
}

.page-header::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 0;
  width: 120px;
  height: 4px;
  background: var(--gradiente-luxo);
  border-radius: var(--raio-full);
  box-shadow: var(--sombra-dourada);
}

.page-header h1 {
  font-family: var(--fonte-display);
  font-size: 2.75rem;
  font-weight: var(--peso-extrabold);
  color: var(--azul-noite);
  margin-bottom: var(--espacamento-sm);
  letter-spacing: -0.02em;
}

.page-header p {
  color: var(--marrom-cafe);
  font-size: 1.125rem;
  font-weight: var(--peso-medium);
}

/* ========== CARDS PREMIUM ========== */
.card {
  background: var(--branco-puro);
  border-radius: var(--raio-xl);
  box-shadow: var(--sombra-sm);
  overflow: hidden;
  transition: all var(--transicao-normal);
  border: 1px solid var(--cinza-platina);
}

.card:hover {
  box-shadow: var(--sombra-md);
  transform: translateY(-2px);
  border-color: var(--dourado-claro);
}

.card-header {
  padding: var(--espacamento-xl);
  border-bottom: 1px solid var(--cinza-platina);
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.05), rgba(201, 116, 88, 0.03));
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 1.5rem;
  font-weight: var(--peso-bold);
  color: var(--azul-noite);
  margin: 0;
  font-family: var(--fonte-display);
}

.card-body {
  padding: var(--espacamento-xl);
}

/* ========== TABELAS ELEGANTES ========== */
.table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
}

.table thead th {
  text-align: left;
  padding: var(--espacamento-md) var(--espacamento-lg);
  font-weight: var(--peso-bold);
  color: var(--azul-noite);
  font-size: 0.875rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  border-bottom: 2px solid var(--cinza-platina);
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.05), rgba(201, 116, 88, 0.03));
}

.table tbody td {
  padding: var(--espacamento-lg);
  border-bottom: 1px solid var(--cinza-platina);
  color: var(--marrom-cafe);
  font-size: 0.9375rem;
}

.table tbody tr {
  transition: all var(--transicao-rapida);
  background: transparent;
}

.table tbody tr:hover {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.03), rgba(201, 116, 88, 0.02));
}

.table tbody tr:last-child td {
  border-bottom: none;
}

/* ========== BOTÕES PREMIUM ========== */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--espacamento-sm);
  padding: 1rem 2rem;
  border: none;
  border-radius: var(--raio-lg);
  font-weight: var(--peso-semibold);
  font-size: 1rem;
  cursor: pointer;
  transition: all var(--transicao-normal);
  position: relative;
  overflow: hidden;
  font-family: var(--fonte-principal);
}

.btn-primary {
  background: var(--gradiente-luxo);
  color: var(--branco-puro);
  box-shadow: var(--sombra-dourada);
  border: none;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 12px 40px rgba(212, 175, 55, 0.35);
}

.btn-secondary {
  background: var(--branco-puro);
  color: var(--azul-noite);
  border: 2px solid var(--cinza-platina);
  box-shadow: var(--sombra-xs);
}

.btn-secondary:hover {
  border-color: var(--dourado-champagne);
  box-shadow: var(--sombra-sm);
  transform: translateY(-2px);
}

.btn-text {
  background: none;
  color: var(--dourado-champagne);
  padding: var(--espacamento-sm) var(--espacamento-md);
  font-weight: var(--peso-bold);
  border-radius: var(--raio-md);
}

.btn-text:hover {
  background: linear-gradient(135deg, rgba(212, 175, 55, 0.08), rgba(201, 116, 88, 0.05));
}

/* ========== LOADING ========== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  gap: var(--espacamento-lg);
}

.loading-spinner {
  width: 80px;
  height: 80px;
}

.loading-container p {
  color: var(--marrom-cafe);
  font-size: 1.125rem;
  font-weight: var(--peso-semibold);
}

/* ========== BADGES ========== */
.badge {
  display: inline-flex;
  align-items: center;
  padding: 0.375rem 0.875rem;
  border-radius: var(--raio-full);
  font-size: 0.8125rem;
  font-weight: var(--peso-bold);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.badge-success {
  background: var(--sucesso-claro);
  color: var(--sucesso);
  border: 1px solid var(--sucesso-borda);
}

.badge-warning {
  background: var(--alerta-claro);
  color: var(--alerta);
  border: 1px solid var(--alerta-borda);
}

.badge-error {
  background: var(--erro-claro);
  color: var(--erro);
  border: 1px solid var(--erro-borda);
}

.badge-info {
  background: var(--info-claro);
  color: var(--info);
  border: 1px solid var(--info-borda);
}

/* ========== RESPONSIVO ========== */
@media (max-width: 768px) {
  .main-content {
    margin-left: 0;
  }
  
  .page-header h1 {
    font-size: 2.25rem;
  }
}

/* ========== ANIMAÇÕES ========== */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes shimmer {
  0% {
    background-position: -1000px 0;
  }
  100% {
    background-position: 1000px 0;
  }
}

.animate-fade-in-up {
  animation: fadeInUp 0.6s cubic-bezier(0.4, 0, 0.2, 1) forwards;
}

.shimmer {
  background: linear-gradient(
    90deg,
    rgba(212, 175, 55, 0.1) 0%,
    rgba(212, 175, 55, 0.3) 50%,
    rgba(212, 175, 55, 0.1) 100%
  );
  background-size: 1000px 100%;
  animation: shimmer 2s infinite linear;
}
</file>

