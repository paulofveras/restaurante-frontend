  --transicao-normal: 350ms cubic-bezier(0.4, 0, 0.2, 1);
  --transicao-suave: 500ms cubic-bezier(0.4, 0, 0.2, 1);
  
  /* ========== Z-INDEX ========== */
  --z-base: 1;
  --z-dropdown: 100;
  --z-sticky: 200;
  --z-sidebar: 300;
  --z-header: 400;
  --z-modal: 500;
  --z-tooltip: 600;
}

/* ========== TOKENS SEMÂNTICOS ========== */

:root {
  /* Backgrounds */
  --bg-principal: var(--creme-premium);
  --bg-card: var(--branco-puro);
  --bg-hover: var(--creme-escuro);
  
  /* Textos */
  --texto-principal: var(--azul-noite);
  --texto-secundario: var(--marrom-cafe);
  --texto-terciario: var(--cinza-grafite);
