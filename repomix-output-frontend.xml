.stat-card {
  background: var(--branco);
  border-radius: var(--raio-lg);
  padding: var(--espacamento-xl);
  display: flex;
  gap: var(--espacamento-lg);
  align-items: flex-start;
  box-shadow: var(--sombra-sm);
  transition: all var(--transicao-normal);
  position: relative;
  overflow: hidden;
  border: 1px solid rgba(250, 204, 21, 0.15);
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4px;
  background: var(--gradiente-principal);
  opacity: 0;
  transition: opacity var(--transicao-normal);
}

.stat-card:hover::before {
  opacity: 1;
}

/* Efeito de brilho */
.stat-shine {
  position: absolute;
  top: -50%;
  right: -50%;
  bottom: -50%;
  left: -50%;
  background: linear-gradient(
    to bottom,
    rgba(255, 255, 255, 0) 0%,
    rgba(255, 255, 255, 0.1) 50%,
    rgba(255, 255, 255, 0) 100%
  );
  transform: rotate(45deg);
  opacity: 0;
  transition: opacity var(--transicao-suave);
  pointer-events: none;
}

.stat-card:hover .stat-shine {
  opacity: 1;
  animation: shine 1.5s ease-in-out;
}

@keyframes shine {
  0% { transform: translateX(-100%) rotate(45deg); }
  100% { transform: translateX(100%) rotate(45deg); }
}

/* Ícone */
.stat-icon-wrapper {
  flex-shrink: 0;
}

.stat-icon {
  width: 64px;
  height: 64px;
  border-radius: var(--raio-md);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  background: var(--gradiente-card);
  position: relative;
  box-shadow: var(--sombra-sm);
}

.stat-icon::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: var(--raio-md);
  background: var(--gradiente-principal);
  opacity: 0;
  transition: opacity var(--transicao-normal);
}

.stat-card:hover .stat-icon::after {
  opacity: 0.15;
}

/* Conteúdo */
.stat-content {
  flex: 1;
  min-width: 0;
}

.stat-label {
  font-size: 0.875rem;
  color: var(--cinza-medio);
  margin: 0 0 var(--espacamento-sm) 0;
  font-weight: var(--peso-medium);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.stat-value {
  font-size: 2rem;
  font-weight: var(--peso-bold);
  color: var(--azul-tocantins);
  margin: 0 0 var(--espacamento-sm) 0;
  line-height: 1;
  font-family: var(--fonte-display);
}

/* Trend */
.stat-trend {
  display: inline-flex;
  align-items: center;
  gap: var(--espacamento-xs);
  font-size: 0.875rem;
  font-weight: var(--peso-semibold);
  padding: var(--espacamento-xs) var(--espacamento-sm);
  border-radius: var(--raio-sm);
}

.trend-icon {
  font-size: 1rem;
}

.trend-positive {
  background: var(--sucesso-claro);
  color: var(--sucesso);
}

.trend-negative {
  background: var(--erro-claro);
  color: var(--erro);
}

.trend-neutral {
  background: var(--info-claro);
  color: var(--info);
}

/* Responsivo */
@media (max-width: 640px) {
  .stat-card {
    padding: var(--espacamento-lg);
  }

  .stat-icon {
    width: 56px;
    height: 56px;
    font-size: 1.75rem;
  }

  .stat-value {
    font-size: 1.75rem;
  }
}
</file>

