.sidebar {
  width: 280px;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(20px);
  border-right: 1px solid rgba(251, 146, 60, 0.2);
  display: flex;
  flex-direction: column;
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  z-index: var(--z-sidebar);
  box-shadow: 4px 0 24px rgba(251, 146, 60, 0.12);
}

/* ========== HEADER COM LOGO ========== */
.sidebar-header {
  padding: var(--espacamento-xl);
  border-bottom: 1px solid rgba(251, 146, 60, 0.15);
  background: linear-gradient(135deg, rgba(254, 243, 199, 0.6), rgba(254, 215, 170, 0.4));
}

.logo {
  display: flex;
  align-items: center;
  gap: var(--espacamento-md);
  cursor: pointer;
}

.logo-imagem {
  width: 56px;
  height: 56px;
  flex-shrink: 0;
  position: relative;
}

.logo-imagem img {
  width: 100%;
