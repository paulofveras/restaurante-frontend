<file path="src/components/Badge.css">
.badge {
  display: inline-flex;
  align-items: center;
  gap: var(--espacamento-xs);
  padding: var(--espacamento-sm) var(--espacamento-md);
  border-radius: var(--raio-full);
  font-size: 0.8125rem;
  font-weight: var(--peso-semibold);
  text-transform: uppercase;
  letter-spacing: 0.025em;
  line-height: 1;
  cursor: default;
  transition: all var(--transicao-normal);
  position: relative;
  overflow: hidden;
}

.badge::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  transform: translate(-50%, -50%);
  transition: width 0.6s, height 0.6s;
}

.badge:hover::before {
  width: 100px;
  height: 100px;
}

.badge-icon {
  font-size: 0.875rem;
  display: flex;
  align-items: center;
}

.badge-label {
  position: relative;
  z-index: 1;
}

/* Recebido (Azul) */
.badge-recebido {
  background: linear-gradient(135deg, #DBEAFE 0%, #BFDBFE 100%);
  color: #1E40AF;
  border: 1px solid #93C5FD;
}

/* Em Preparo (Amarelo) */
.badge-preparo {
  background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
  color: #92400E;
  border: 1px solid #FCD34D;
}

/* Pronto (Verde) */
.badge-pronto {
  background: linear-gradient(135deg, #D1FAE5 0%, #A7F3D0 100%);
  color: #065F46;
  border: 1px solid #6EE7B7;
}

/* Entregue (Roxo) */
.badge-entregue {
  background: linear-gradient(135deg, #E0E7FF 0%, #C7D2FE 100%);
  color: #5B21B6;
  border: 1px solid #A5B4FC;
}

/* Cancelado (Vermelho) */
.badge-cancelado {
  background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
  color: #991B1B;
  border: 1px solid #FCA5A5;
}

/* Default */
.badge-default {
  background: linear-gradient(135deg, #F3F4F6 0%, #E5E7EB 100%);
  color: #374151;
  border: 1px solid #D1D5DB;
}

/* Animação de pulso */
@keyframes pulse-badge {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.05);
  }
}

.badge-preparo {
  animation: pulse-badge 2s ease-in-out infinite;
}
</file>

<file path="src/components/Badge.jsx">
import React from 'react';
import { motion } from 'framer-motion';
import './Badge.css';

const Badge = ({ status }) => {
  const getStatusConfig = (status) => {
    const configs = {
      0: { label: 'Recebido', class: 'badge-recebido', icon: '🔔' },
      1: { label: 'Em Preparo', class: 'badge-preparo', icon: '👨‍🍳' },
      2: { label: 'Pronto', class: 'badge-pronto', icon: '✅' },
      3: { label: 'Entregue', class: 'badge-entregue', icon: '🎉' },
      4: { label: 'Cancelado', class: 'badge-cancelado', icon: '❌' }
    };
    return configs[status] || { label: 'Desconhecido', class: 'badge-default', icon: '❓' };
  };

  const config = getStatusConfig(status);

  return (
    <motion.span
      className={`badge ${config.class}`}
      initial={{ scale: 0, opacity: 0 }}
      animate={{ scale: 1, opacity: 1 }}
      whileHover={{ scale: 1.05 }}
      transition={{ type: 'spring', stiffness: 300, damping: 20 }}
    >
      <span className="badge-icon">{config.icon}</span>
      <span className="badge-label">{config.label}</span>
    </motion.span>
  );
};

export default Badge;
</file>

